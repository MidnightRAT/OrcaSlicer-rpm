+# --- System library discovery (USE_SYSTEM_DEPS mode) ---
+# Only leaf deps that have no dependents in the bundle can be safely replaced.
+# Boost/TBB/OpenEXR/Blosc/GMP/MPFR/Eigen are depended on by OpenVDB/CGAL.
+if(USE_SYSTEM_DEPS)
+    message(STATUS "USE_SYSTEM_DEPS: Probing for system libraries (leaf deps only)...")
+    set(_save_cmake_module_path "${CMAKE_MODULE_PATH}")
+    list(APPEND CMAKE_MODULE_PATH "/usr/lib64/cmake" "/usr/share/cmake/Modules")
+    find_package(NLopt QUIET)
+    find_package(Qhull QUIET)
+    find_package(OpenCV QUIET COMPONENTS core imgcodecs imgproc)
+    find_package(OpenCASCADE QUIET)
+    set(CMAKE_MODULE_PATH "${_save_cmake_module_path}")
+    foreach(_pkg NLopt Qhull OpenCV OpenCASCADE)
+        string(TOUPPER "${_pkg}" _pkg_upper)
+        if(${_pkg}_FOUND OR ${_pkg_upper}_FOUND)
+            message(STATUS "  System ${_pkg}: FOUND")
+        else()
+            message(STATUS "  System ${_pkg}: NOT found (will build from source)")
+        endif()
+    endforeach()
+endif()
+
