+# Filter _dep_list when using system deps
+if(USE_SYSTEM_DEPS)
+    set(_filtered_dep_list "")
+    foreach(_dep ${_dep_list})
+        if(TARGET ${_dep})
+            list(APPEND _filtered_dep_list ${_dep})
+        else()
+            message(STATUS "USE_SYSTEM_DEPS: Skipping ${_dep} (system library used)")
+        endif()
+    endforeach()
+    set(_dep_list ${_filtered_dep_list})
+endif()
